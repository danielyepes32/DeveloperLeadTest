# Copy to .env and adjust. NEVER commit real secrets.
APP_ENV=development
LOG_LEVEL=INFO

# Database (matches docker-compose service "db")
DATABASE_URL=postgresql+psycopg://app:app@db:5432/procurement

# Auth — generate a strong secret in production:  openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
